# Plantilla de variables de entorno del backend.
# Copia este archivo a `.env` y completa con valores reales (NO lo subas a git).

# Puerto del servidor Express (el frontend espera 4000 en apiClient.baseURL)
PORT=4000

# Cadena de conexión a MongoDB.
# NOTA: hoy db.conf.js hardcodea "mongodb://localhost:27017/StyleBusters" e ignora esta variable.
# Ver docs/known-issues.md#K02 (pendiente: leer la URI desde aquí).
MONGODB_URI=mongodb://localhost:27017/StyleBusters

# Secreto de firma del access token JWT (usar un valor largo y aleatorio)
JWT_SECRET=change_me_use_a_long_random_secret

# Secreto de firma del refresh token JWT (distinto del anterior)
JWT_REFRESH_TOKEN=change_me_use_another_long_random_secret

# OBLIGATORIO: secreto que habilita el registro como admin.
# Si se deja vacío/indefinido, cualquier registro sin el campo adminSecret se crea como admin
# (ver docs/known-issues.md#K01). Debe tener un valor no vacío.
ADMIN_SECRET=change_me_admin_registration_secret

# Nota: JWT_EXPIRES_IN / JWT_REFRESH_EXPIRES_IN existían en el .env pero el código
# actualmente hardcodea "1h" / "7d" (ver docs/known-issues.md#K12).
